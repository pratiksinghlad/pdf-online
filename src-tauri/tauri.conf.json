{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PDF Online",
  "version": "0.1.0",
  "identifier": "com.pdfonline",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PDF Online",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {}
    },
    "icon": [
      "../public/icon.png",
      "../public/icon.ico"
    ]
  }
}
