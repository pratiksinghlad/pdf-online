{
  "playwright-validation": {
    "enabled": true,
    "PostToolUse": [
      {
        "matcher": ".*write_to_file.*|.*replace_file_content.*|.*multi_replace_file_content.*",
        "hooks": [
          {
            "type": "command",
            "command": "npm run test:ui"
          }
        ]
      }
    ]
  }
}
